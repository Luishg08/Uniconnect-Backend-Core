model group_join_request {
  id_request    Int       @id @default(autoincrement())
  id_group      Int
  requester_id  Int
  status        String    @default("pending") @db.VarChar // pending, accepted, rejected
  requested_at  DateTime  @default(now()) @db.Timestamptz(6)
  responded_at  DateTime? @db.Timestamptz(6)

  group     group? @relation(fields: [id_group], references: [id_group], onDelete: Cascade)
  requester user?  @relation(fields: [requester_id], references: [id_user], onDelete: Cascade)

  @@unique([id_group, requester_id])
  @@index([id_group, status])
  @@index([requester_id, status])
}
